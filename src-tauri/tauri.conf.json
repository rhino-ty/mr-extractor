{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MR Extractor",
  "version": "0.1.0",
  "identifier": "com.rhinoty.mr-extractor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm setup:binaries && pnpm dev",
    "beforeBuildCommand": "pnpm setup:binaries && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "MR Extractor",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/queue-tmp/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe",
      "binaries/yt-dlp"
    ],
    "resources": [
      "binaries/python/**/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
